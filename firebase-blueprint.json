{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the shared expense tracker.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "name": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role." }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "An expense category.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The category name." },
        "color": { "type": "string", "description": "The category color." },
        "icon": { "type": "string", "description": "The category icon name." }
      },
      "required": ["name", "color", "icon"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An expense record.",
      "type": "object",
      "properties": {
        "amount": { "type": "number", "description": "The expense amount." },
        "categoryId": { "type": "string", "description": "The ID of the category." },
        "description": { "type": "string", "description": "Optional description." },
        "date": { "type": "string", "format": "date-time", "description": "The date of the expense." },
        "createdBy": { "type": "string", "description": "The UID of the user who created the expense." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["amount", "categoryId", "date", "createdBy", "createdAt", "updatedAt"]
    },
    "ExpenseHistory": {
      "title": "ExpenseHistory",
      "description": "Audit log for expenses.",
      "type": "object",
      "properties": {
        "expenseId": { "type": "string", "description": "The ID of the expense." },
        "action": { "type": "string", "enum": ["create", "update", "delete"], "description": "The action performed." },
        "previousData": { "type": "string", "description": "JSON string of the previous data." },
        "newData": { "type": "string", "description": "JSON string of the new data." },
        "changedBy": { "type": "string", "description": "The UID of the user who made the change." },
        "timestamp": { "type": "string", "format": "date-time", "description": "The time of the change." }
      },
      "required": ["expenseId", "action", "changedBy", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Stores expense categories."
    },
    "/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Stores expenses."
    },
    "/expenseHistory/{historyId}": {
      "schema": { "$ref": "#/entities/ExpenseHistory" },
      "description": "Stores audit logs for expenses."
    }
  }
}
